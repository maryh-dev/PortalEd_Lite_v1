<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/superficie"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivAvatarUsuario"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@color/azul_secundario"
            android:src="@drawable/ic_perfil"
            app:tint="@color/texto_sobre_azul" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNomeUsuario"
                style="@style/TextoCardTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nome do Usuário" />

            <TextView
                android:id="@+id/tvEmailUsuario"
                style="@style/TextoCardSecundario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="email@exemplo.com" />

            <TextView
                android:id="@+id/tvTipoUsuario"
                style="@style/TextoCardSecundario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aluno"
                android:textColor="@color/azul_primario"
                android:textStyle="italic" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivRemoverUsuario"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_delete" />

    </LinearLayout>
</androidx.cardview.widget.CardView>